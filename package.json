{
  "name": "cells",
  "version": "0.1.17",
  "private": true,
  "type": "module",
  "author": "Raj Sharma <r@raj.how>",
  "description": "Infinite desktop workspace for terminals, browsers, and agent workflows.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xrehpicx/cells.git"
  },
  "bugs": {
    "url": "https://github.com/xrehpicx/cells/issues"
  },
  "homepage": "https://github.com/xrehpicx/cells",
  "keywords": [
    "electron",
    "terminal",
    "workspace",
    "developer-tools",
    "agents",
    "react"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:raw": "CELLS_DEV_ROOT=\"${CELLS_DEV_ROOT:-$HOME/.cells-dev}\" vite",
    "build": "pnpm typecheck && vite build",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:electron",
    "typecheck:app": "tsc --noEmit --project tsconfig.json",
    "typecheck:electron": "tsc --noEmit --project tsconfig.node.json",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "pnpm build && electron-builder --dir",
    "release": "pnpm build && electron-builder --publish always",
    "release:local": "pnpm build && electron-builder",
    "changeset": "changeset",
    "version": "changeset version",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'electron/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'electron/**/*.ts'",
    "prepare": "git config core.hooksPath .githooks"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "prettier --write",
    "electron/**/*.ts": "prettier --write"
  },
  "build": {
    "appId": "com.cells.app",
    "productName": "Cells",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "x64ArchFiles": "Contents/Resources/app.asar.unpacked/node_modules/node-pty/prebuilds/darwin-{arm64,x64}/{pty.node,spawn-helper}",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Cells",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "xrehpicx",
      "repo": "cells"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@lobehub/icons": "^5.0.1",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@tanstack/react-hotkeys": "^0.6.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "ghostty-web": "^0.4.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.38.0",
    "nanoid": "^5.0.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
