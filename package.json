{
  "name": "cells",
  "version": "0.1.170",
  "private": true,
  "type": "module",
  "author": "Raj Sharma <r@raj.how>",
  "description": "Infinite desktop workspace for terminals, browsers, and agent workflows.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xrehpicx/cells.git"
  },
  "bugs": {
    "url": "https://github.com/xrehpicx/cells/issues"
  },
  "homepage": "https://github.com/xrehpicx/cells",
  "keywords": [
    "electron",
    "terminal",
    "workspace",
    "developer-tools",
    "agents",
    "react"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.6.3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm prepare:terminal-bundles && node scripts/dev.mjs",
    "dev:raw": "CELLS_DEV_ROOT=\"${CELLS_DEV_ROOT:-$HOME/.cells-dev}\" vite",
    "prepare:terminal-bundles": "pnpm prepare:zellij-bundle && pnpm prepare:tmux-bundle",
    "prepare:terminal-bundles:release": "pnpm prepare:zellij-bundle && pnpm prepare:tmux-bundle:release",
    "prepare:zellij-bundle": "node scripts/prepare-zellij-bundle.mjs",
    "prepare:tmux-bundle": "node scripts/prepare-tmux-bundle.mjs",
    "prepare:tmux-bundle:release": "CELLS_TMUX_TARGETS=darwin-arm64,darwin-x64 CELLS_TMUX_REQUIRE_TARGETS=1 node scripts/prepare-tmux-bundle.mjs",
    "prepare:mcp-server": "CI=true pnpm --dir mcp-server install --frozen-lockfile && pnpm --dir mcp-server build",
    "typecheck:mcp-server": "CI=true pnpm --dir mcp-server install --frozen-lockfile && pnpm --dir mcp-server typecheck",
    "build": "pnpm prepare:mcp-server && pnpm prepare:terminal-bundles && pnpm typecheck && pnpm build:vite",
    "build:vite": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:electron && pnpm typecheck:mcp-server",
    "typecheck:app": "tsc --noEmit --project tsconfig.json",
    "typecheck:electron": "tsc --noEmit --project tsconfig.node.json",
    "test:tmux-session-manager": "pnpm build && node --test scripts/test-tmux-session-manager.mjs",
    "test:zellij-session-manager": "pnpm build && node --test scripts/test-zellij-session-manager.mjs",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "pnpm prepare:mcp-server && pnpm prepare:terminal-bundles:release && pnpm typecheck && pnpm build:vite && electron-builder --dir",
    "release": "pnpm prepare:mcp-server && pnpm prepare:terminal-bundles:release && pnpm typecheck && pnpm build:vite && electron-builder --publish always",
    "release:local": "pnpm prepare:mcp-server && pnpm prepare:terminal-bundles:release && pnpm typecheck && pnpm build:vite && electron-builder",
    "changeset": "changeset",
    "version": "changeset version",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'electron/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'electron/**/*.ts'",
    "prepare": "git config core.hooksPath .githooks"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "prettier --write",
    "electron/**/*.ts": "prettier --write"
  },
  "build": {
    "appId": "com.cells.app",
    "productName": "Cells",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "!resources/vendor/zellij/**/*",
      "!resources/vendor/tmux/**/*"
    ],
    "asar": {
      "smartUnpack": false
    },
    "asarUnpack": [
      "**/node_modules/node-pty/**/*.{node,exe}",
      "**/node_modules/node-pty/**/spawn-helper",
      "**/node_modules/@anthropic-ai/claude-agent-sdk/vendor/**",
      "**/node_modules/koffi/build/**/*.node",
      "**/node_modules/@openai/codex-darwin-*/vendor/**",
      "**/node_modules/@cursor/sdk-darwin-*/bin/**",
      "**/node_modules/@github/copilot/prebuilds/**",
      "**/node_modules/@github/copilot/ripgrep/bin/**",
      "**/node_modules/@github/copilot-darwin-*/copilot",
      "**/node_modules/sqlite3/**/*.node"
    ],
    "extraResources": [
      {
        "from": "mcp-server/dist/index.js",
        "to": "mcp-server/dist/index.js"
      },
      {
        "from": "resources/vendor/zellij",
        "to": "vendor/zellij"
      },
      {
        "from": "resources/vendor/tmux",
        "to": "vendor/tmux"
      },
      {
        "from": "src/fonts",
        "to": "vendor/fonts"
      }
    ],
    "fileAssociations": [
      {
        "ext": [
          "txt",
          "text",
          "md",
          "markdown",
          "json",
          "jsonc",
          "js",
          "jsx",
          "ts",
          "tsx",
          "css",
          "scss",
          "html",
          "xml",
          "yml",
          "yaml",
          "toml",
          "ini",
          "env",
          "sh",
          "bash",
          "zsh",
          "py",
          "rb",
          "go",
          "rs",
          "java",
          "c",
          "h",
          "cpp",
          "hpp",
          "cs",
          "swift",
          "kt",
          "kts",
          "sql",
          "graphql",
          "gql"
        ],
        "name": "Text and Source Files",
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "x64ArchFiles": "Contents/Resources/{app.asar.unpacked/node_modules/{node-pty/prebuilds/darwin-{arm64,x64}/{pty.node,spawn-helper},@anthropic-ai/claude-agent-sdk/vendor/{audio-capture/{arm64,x64}-darwin/audio-capture.node,ripgrep/{arm64,x64}-darwin/rg},koffi/build/koffi/darwin_{arm64,x64}/koffi.node,@openai/codex-darwin-{arm64,x64}/vendor/{aarch64,x86_64}-apple-darwin/**/*,@cursor/sdk-darwin-{arm64,x64}/bin/{cursorsandbox,rg},@github/copilot/prebuilds/darwin-{arm64,x64}/{pty.node,keytar.node,spawn-helper,computer.node},@github/copilot/ripgrep/bin/darwin-{arm64,x64}/rg,@github/copilot-darwin-{arm64,x64}/copilot,sqlite3/**/*.node},vendor/zellij/darwin-{arm64,x64}/zellij,vendor/tmux/darwin-{arm64,x64}/tmux}",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Cells",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "xrehpicx",
      "repo": "cells"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@base-ui/react": "^1.3.0",
    "@cursor/sdk": "^1.0.11",
    "@fontsource-variable/geist": "^5.2.8",
    "@github/copilot-sdk": "^0.3.0",
    "@legendapp/list": "3.0.0-beta.44",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@openai/codex-sdk": "^0.121.0",
    "@opencode-ai/sdk": "^1.4.0",
    "@pierre/diffs": "^1.1.20",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-hotkeys": "^0.6.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "execa": "^9.6.1",
    "ghostty-web": "^0.4.0",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "motion": "^12.38.0",
    "nanoid": "^5.0.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-haptics": "^0.0.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "0.25.12",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fastmcp": "^3.34.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "sqlite3"
    ],
    "supportedArchitectures": {
      "os": [
        "darwin"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  }
}
